/*
 * This pipeline is launched from gepabds/nextflow. Without a project-local
 * nextflow.config, the user's ~/.nextflow/config can supply docker.runOptions
 * (e.g. -u $(id -u):$(id -g)), which runs the container as a non-root user
 * and breaks tools installed under /root/.local/bin (e.g. gepabds).
 *
 * runOptions = '' explicitly overrides that so the image default user (root)
 * matches the Docker build.
 */
profiles {

    docker {
        docker {
            enabled    = true
            runOptions = ''
        }
    }
}
